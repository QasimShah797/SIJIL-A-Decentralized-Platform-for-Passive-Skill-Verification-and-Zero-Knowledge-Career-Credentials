# Server
PORT=5000
NODE_ENV=development

# Remote Supabase (same project as frontend VITE_SUPABASE_URL)
# Dashboard → Project Settings → API
SUPABASE_URL=https://nhzvtqpplfruzocframc.supabase.co
SUPABASE_ANON_KEY=your_anon_jwt_key
# service_role — NEVER expose to frontend; required for npm run seed:institution
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

CORS_ORIGIN=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# Gmail SMTP — peer review invitation emails
# Use a Google App Password (not your regular Gmail password):
# Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-app@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=SIJIL <your-app@gmail.com>
