# GitHub OAuth App: https://github.com/settings/developers
# Callback URL must match VITE_GITHUB_REDIRECT_URI exactly
VITE_GITHUB_CLIENT_ID=Ov23lixie3I0seKa7A2t
VITE_GITHUB_REDIRECT_URI=http://localhost:8080/auth/github/callback

# Supabase → Project Settings → API (use anon JWT key, NOT sb_publishable_*)
VITE_SUPABASE_URL=https://nhzvtqpplfruzocframc.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_jwt_key

# IMPORTANT: .env.local overrides .env — keep VITE_GITHUB_CLIENT_ID identical in both files.
#
# Supabase Edge Function secrets (must match the same GitHub OAuth app):
#   supabase secrets set GITHUB_OAUTH_CLIENT_ID=Ov23lixie3I0seKa7A2t
#   supabase secrets set GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret
#   npm run supabase:deploy-github
